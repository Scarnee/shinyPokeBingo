# Dependencies
node_modules/

# Build outputs
dist/
apps/*/dist/
apps/frontend/build/

# Environment variables — NEVER commit secrets
.env
.env.local
.env.*.local
.env.production

# AWS / SSH keys — NEVER commit private keys
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
*.pub

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Claude Code local config
.claude/settings.local.json

# Test coverage
coverage/
lcov.info
*.lcov

# Docker local override (contains machine-specific or secret config)
docker-compose.override.yml

# TypeScript cache
*.tsbuildinfo
