PORT=3000
FRONTEND_URL=https://shinybingogenerator.com

# Path where PokéAPI responses are cached to disk.
# Leave empty to disable disk cache (data lost on restart).
# In Docker, this should point to a mounted volume.
CACHE_DIR=/app/cache

# Override to point at a self-hosted PokéAPI instance.
# Leave empty to use the public pokeapi.co.
POKEAPI_BASE_URL=
